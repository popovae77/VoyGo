# Скопируйте на сервер один раз: cp deploy/.env.production.example .env

DATABASE_URL=sqlite:///./data/voyago.db
SECRET_KEY=сгенерируйте-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://vayago.ru,http://www.vayago.ru

# Письма: SMTP с VPS часто блокируется — пока APP_DEBUG=true, ссылка сброса на экране
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=voyago_trip@mail.ru
SMTP_PASSWORD=пароль-приложения-mail-ru
SMTP_FROM=Voyago <voyago_trip@mail.ru>
SMTP_USE_TLS=false
SMTP_USE_SSL=true

APP_PUBLIC_URL=http://vayago.ru
APP_DEBUG=true

PRICING_PROVIDER=travelpayouts
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
DEFAULT_ORIGIN_IATA=MOW

SERPAPI_API_KEY=
MAKCORPS_USERNAME=
MAKCORPS_PASSWORD=
MAKCORPS_JWT=
MAKCORPS_USD_TO_RUB=95

RANVIK_API_KEY=
RANVIK_MODEL=deepseek-v4-flash
RANVIK_API_URL=https://api.ranvik.ru/v1/chat/completions
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
