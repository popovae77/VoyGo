# Скопируйте на сервер как .env в корне проекта:
#   cp deploy/.env.production.example .env
# Заполните секреты. НЕ коммитьте .env в git.

DATABASE_URL=sqlite:///./data/voyago.db
SECRET_KEY=сгенерируйте-длинный-случайный-ключ
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=https://voyago.bizml.ru

# Почта: на VPS SMTP Mail.ru часто работает; с домашнего интернета — brevo
EMAIL_PROVIDER=brevo
BREVO_API_KEY=

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=voyago_trip@mail.ru
SMTP_PASSWORD=
SMTP_FROM=Voyago <voyago_trip@mail.ru>
SMTP_USE_TLS=false
SMTP_USE_SSL=true

APP_PUBLIC_URL=https://voyago.bizml.ru
APP_DEBUG=false

PRICING_PROVIDER=travelpayouts
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
DEFAULT_ORIGIN_IATA=MOW

SERPAPI_API_KEY=
MAKCORPS_USERNAME=
MAKCORPS_PASSWORD=
MAKCORPS_JWT=
MAKCORPS_USD_TO_RUB=95

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

TELEGRAM_BOT_TOKEN=
