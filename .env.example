DATABASE_URL=sqlite:///./data/voyago.db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Письма: регистрация, сброс пароля
# smtp — напрямую (часто блокируется провайдером на портах 465/587)
# rusender — российский сервис, HTTPS API (рекомендуется для РФ)
# unisender — UniSender Go, HTTPS API
# brevo — зарубежный аналог (если нужен)
EMAIL_PROVIDER=rusender
RUSENDER_API_KEY=
UNISENDER_API_KEY=
UNISENDER_API_URL=https://goapi.unisender.ru/ru/transactional/api/v1
BREVO_API_KEY=

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your@mail.ru
SMTP_PASSWORD=app-password-from-mail-ru
SMTP_FROM=Voyago <your@mail.ru>
SMTP_USE_TLS=false
SMTP_USE_SSL=true
APP_PUBLIC_URL=http://127.0.0.1:8000
APP_DEBUG=false

TELEGRAM_BOT_TOKEN=

PRICING_PROVIDER=travelpayouts
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
DEFAULT_ORIGIN_IATA=MOW

# Жильё: SerpApi → Makcorps → Hotellook → каталог
SERPAPI_API_KEY=
MAKCORPS_USERNAME=
MAKCORPS_PASSWORD=
MAKCORPS_JWT=
MAKCORPS_USD_TO_RUB=95

# ИИ: Gemini (приоритет) или Groq
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
