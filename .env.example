DATABASE_URL=sqlite:///./data/voyago.db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Письма: smtp (Mail.ru) — с Mac может не работать; APP_DEBUG=true покажет ссылку сброса на экране
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your@mail.ru
SMTP_PASSWORD=app-password-from-mail-ru
SMTP_FROM=Voyago <your@mail.ru>
SMTP_USE_TLS=false
SMTP_USE_SSL=true
APP_PUBLIC_URL=http://127.0.0.1:8000
APP_DEBUG=true

TELEGRAM_BOT_TOKEN=

PRICING_PROVIDER=travelpayouts
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
DEFAULT_ORIGIN_IATA=MOW

# Жильё: SerpApi → Makcorps → Hotellook → каталог
SERPAPI_API_KEY=
MAKCORPS_USERNAME=
MAKCORPS_PASSWORD=
MAKCORPS_JWT=
MAKCORPS_USD_TO_RUB=95

# ИИ: Ranvik (приоритет в РФ) → Groq → Gemini
RANVIK_API_KEY=
RANVIK_MODEL=deepseek-v4-flash
RANVIK_API_URL=https://api.ranvik.ru/v1/chat/completions
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
